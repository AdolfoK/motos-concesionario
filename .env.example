# Copia este archivo a .env y ajusta los valores.
# docker-compose toma estos valores automaticamente.

# --- Base de datos ---
POSTGRES_DB=concesionaria
POSTGRES_USER=concesionaria
POSTGRES_PASSWORD=concesionaria

# --- Django ---
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DJANGO_ADMIN_USER=admin
DJANGO_ADMIN_PASSWORD=admin123

# --- WhatsApp (numero de la concesionaria, formato internacional sin + ni espacios) ---
WHATSAPP_NUMERO=56912345678
